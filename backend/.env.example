# Backend Configuration Template
# Copy this to .env and adjust values for your development environment

# Application
DEBUG=true
APP_NAME=Anomaly Detection Dashboard API

# Database
# SQLite (MVP)
DATABASE_URL=sqlite:///./anomaly_detector.db

# PostgreSQL (Production) - uncomment to use
# DATABASE_URL=postgresql://user:password@localhost:5432/anomaly_detector
DATABASE_ECHO=false

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production-12345
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Batch Processing
BATCH_JOB_HOUR=2
BATCH_JOB_MINUTE=0
BATCH_WINDOW_MINUTES=60

# Model
MODEL_PATH=./models/anomaly_model.pkl
MODEL_CHECK_INTERVAL_MINUTES=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true
CORS_METHODS=*
CORS_HEADERS=*

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=500
